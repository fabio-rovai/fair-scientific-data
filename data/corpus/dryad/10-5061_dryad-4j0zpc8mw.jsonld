  "name": "A therapeutic small molecule enhances γ-oscillations and improves cognition/memory in Alzheimer’s disease model mice",
  "author": {
    "name": "Istvan Mody",
    "givenName": "Istvan",
    "familyName": "Mody",
    "affiliation": {
