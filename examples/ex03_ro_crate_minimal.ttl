<https://doi.org/10.5281/zenodo.3541888>
    a dcat:Dataset ;
    dct:identifier <https://doi.org/10.5281/zenodo.3541888> ;
    dct:title "RO-Crate Metadata Specification 1.1"^^xsd:string ;
    dct:description "The RO-Crate Metadata Specification 1.1 defines a lightweight approach to packaging research data with their metadata using schema.org annotations in a JSON-LD file. It is based on schema.org and the W3C PROV-O vocabulary for provenance, and aims for FAIR compliance."^^xsd:string ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
