    dcat:keyword "RO-Crate"^^xsd:string ,
                 "research object"^^xsd:string ,
                 "metadata"^^xsd:string ,
                 "FAIR"^^xsd:string ;
    dcat:theme <http://edamontology.org/topic_3366> ;
    schema:variableMeasured "research data package"^^xsd:string ;
    prov:wasDerivedFrom <https://github.com/ResearchObject/ro-crate> ;
    dcat:distribution [
